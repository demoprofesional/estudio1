          "_name": "content1",
          "_customHTML": "<section class=\"mbr-section article content1\">\n    \n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"8\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"8\">\n        <input type=\"range\" inline title=\"Width Content\" name=\"widthContent\" min=\"1\" max=\"4\" step=\"1\" value=\"2\">\n        <input type=\"color\" title=\"Background Color\" name=\"bgColor\" value=\"#434243\">\n    <!-- End block parameters -->\n    </mbr-parameters> \n\n    <div class=\"container\">\n        <div class=\"media-container-row\">\n            <div class=\"mbr-text col-12 mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" data-multiline mbr-article mbr-class=\"{'col-md-6': widthContent == 1, 'col-md-8': widthContent == 2, 'col-md-10': widthContent == 3, 'col-md-12': widthContent == 4}\"><p><br></p><p><br></p><p><br></p><p><br></p></div>\n        </div>\n    </div>\n</section>",
          "_cid": "s6PJ4Zx05w",
          "_anchor": "content1-v",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_params": {
            "modalName": "Demo-WEB",
            "modalSize": "medium",
            "modalHeader": true,
            "modalTitle": "Demo WEB",
            "modalBody": "Esta es una página de D E M O S T R A C I O N.\nSu estructura es modular y está optimizada para ESTUDIOS de PROFESIONALES (CONTABILIDAD, ABOGACIA, ARQUITECTURA, INGENIERIA, DECORACION, OBRAS, etc.).\nLos contenidos son meramente a título de ejemplo. Los nombres, los diseños y las imágenes son de ficción (parte de ellas provenienen de bancos de datos).",
            "modalBodyHTML": true,
            "modalFooter": true,
            "modalCloseBtn": true,
            "modalCloseText": "Cerrar",
            "modalLink": false,
            "modalLinkUrl": "https://mobirise.com/",
            "modalLinkText": "Visit Mobirise",
            "modalLinkNewWindow": true,
            "modalVerticalCenter": true,
            "modalFade": true,
            "modalAutoOpen": false,
            "modalAutoOpenOnce": true,
            "modalAutoOpenGDPR": true,
            "modalAutoOpenDelay": 0
          },
          "modalTest": "<div class=\"mbr-section-btn\">\n  <a href=\"#\" class=\"btn btn-primary display-4\" data-toggle=\"modal\" data-target=\"#Demo-WEB\">Preview Demo-WEB</a>\n  <a href=\"#\" class=\"btn btn-primary display-4\" data-toggle=\"modal\" data-target=\"#Demo-WEB-howtouse\">How to use Demo-WEB</a>\n</div>\n<div class=\"modal fade\" id=\"Demo-WEB-howtouse\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"Demo-WEB-howtouseLabel\" aria-hidden=\"true\">\n  <div class=\"modal-dialog\" role=\"document\" style=\"height:auto\">\n    <div class=\"modal-content\">\n      <div class=\"modal-header\">\n        <h5 class=\"modal-title\" id=\"Demo-WEB-howtouseLabel\">How to use?</h5>\n        <a href=\"\" class=\"close\" data-dismiss=\"modal\" aria-label=\"Close\"><span aria-hidden=\"true\">&times;</span></a>\n      </div>\n      <div class=\"modal-body\">\n        Using your new modal is very easy. Simply create a new link, then click the \"...\" tab and enter the following as custom URL:<br /><br />\n        <code>javascript:OpenModal('Demo-WEB')</code>\n      </div>\n      <div class=\"modal-footer\">\n        <div class=\"mbr-section-btn\"><a href=\"#\" class=\"btn btn-secondary display-4\" data-dismiss=\"modal\">Close</a></div>\n      </div>\n    </div>\n  </div>\n</div>",
          "modalBody": "Esta es una página de D E M O S T R A C I O N.\nSu estructura es modular y está optimizada para ESTUDIOS de PROFESIONALES (CONTABILIDAD, ABOGACIA, ARQUITECTURA, INGENIERIA, DECORACION, OBRAS, etc.).\nLos contenidos son meramente a título de ejemplo. Los nombres, los diseños y las imágenes son de ficción (parte de ellas provenienen de bancos de datos).",
          "alias": "witsec-modal-window",
          "_tags": [
            "Extension"
          ],
          "_name": "witsec-modal-window-block",
          "_anchor": "witsec-modal-window-block-2",
          "modalWindow": "<div class=\"modal fade\" id=\"Demo-WEB\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"Demo-WEBLabel\" aria-hidden=\"true\">  <div class=\"modal-dialog  modal-dialog-centered\" style=\"height:auto\" role=\"document\">    <div class=\"modal-content\"><div class=\"modal-header\">  <h5 class=\"no-anim modal-title\" id=\"Demo-WEBLabel\">Demo WEB</h5>  <a href=\"#\" class=\"no-anim close\" data-dismiss=\"modal\" aria-label=\"Close\"><span aria-hidden=\"true\">&times;</span></a></div><div class=\"modal-body\" id=\"Demo-WEB_body\">Esta es una página de D E M O S T R A C I O N.\nSu estructura es modular y está optimizada para ESTUDIOS de PROFESIONALES (CONTABILIDAD, ABOGACIA, ARQUITECTURA, INGENIERIA, DECORACION, OBRAS, etc.).\nLos contenidos son meramente a título de ejemplo. Los nombres, los diseños y las imágenes son de ficción (parte de ellas provenienen de bancos de datos).</div><div class=\"modal-footer\"><div class=\"mbr-section-btn\"><a href=\"#\" class=\"no-anim btn btn-secondary display-4\" data-dismiss=\"modal\">Cerrar</a></div></div>    </div>  </div></div><script>document.addEventListener(\"DOMContentLoaded\", function() {  $(\"#Demo-WEB\").on(\"hidden.bs.modal\", function () {    var html = $( \"#Demo-WEB_body\" ).html();    $( \"#Demo-WEB_body\" ).empty();    $( \"#Demo-WEB_body\" ).append(html);  })});</script>"
        },
        {
          "_params": {
            "modalName": "Redes-Sociales",
            "modalSize": "medium",
            "modalHeader": true,
            "modalTitle": "Redes Sociales",
            "modalBody": "<h2 class=\"mbr-section-subtitle align-center mbr-light pb-3 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showSubTitle\"> \nEl sitio web posee enlaces con los perfiles de sus cuentas (Twitter, LinkedIN, etc.) de manera que el visitante acceda solo con un click a los contenidos e informaciones allí publicados. </h2>\n\n<div class=\"mbr-figure\" mbr-style=\"{'width': mediaSize + '%'}\">\n                     <img src=\"@PROJECT_PATH@/assets/images/media-998990-640.jpg-640x464.png\" alt=\"Demo WEB  image_pixabay\" title=\"Demo WEB  image_pixabay\">  \n                    </div>",
            "modalBodyHTML": true,
            "modalFooter": true,
            "modalCloseBtn": true,
            "modalCloseText": "Cerrar",
            "modalLink": false,
            "modalLinkUrl": "https://mobirise.com/",
            "modalLinkText": "Visit Mobirise",
            "modalLinkNewWindow": true,
            "modalVerticalCenter": true,
            "modalFade": true,
            "modalAutoOpen": false,
            "modalAutoOpenOnce": true,
            "modalAutoOpenGDPR": true,
            "modalAutoOpenDelay": 0
          },
          "modalTest": "<div class=\"mbr-section-btn\">\n  <a href=\"#\" class=\"btn btn-primary display-4\" data-toggle=\"modal\" data-target=\"#Redes-Sociales\">Preview Redes-Sociales</a>\n  <a href=\"#\" class=\"btn btn-primary display-4\" data-toggle=\"modal\" data-target=\"#Redes-Sociales-howtouse\">How to use Redes-Sociales</a>\n</div>\n<div class=\"modal fade\" id=\"Redes-Sociales-howtouse\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"Redes-Sociales-howtouseLabel\" aria-hidden=\"true\">\n  <div class=\"modal-dialog\" role=\"document\" style=\"height:auto\">\n    <div class=\"modal-content\">\n      <div class=\"modal-header\">\n        <h5 class=\"modal-title\" id=\"Redes-Sociales-howtouseLabel\">How to use?</h5>\n        <a href=\"\" class=\"close\" data-dismiss=\"modal\" aria-label=\"Close\"><span aria-hidden=\"true\">&times;</span></a>\n      </div>\n      <div class=\"modal-body\">\n        Using your new modal is very easy. Simply create a new link, then click the \"...\" tab and enter the following as custom URL:<br /><br />\n        <code>javascript:OpenModal('Redes-Sociales')</code>\n      </div>\n      <div class=\"modal-footer\">\n        <div class=\"mbr-section-btn\"><a href=\"#\" class=\"btn btn-secondary display-4\" data-dismiss=\"modal\">Close</a></div>\n      </div>\n    </div>\n  </div>\n</div>",
          "modalBody": "<h2 class=\"mbr-section-subtitle align-center mbr-light pb-3 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showSubTitle\"> \nEl sitio web posee enlaces con los perfiles de sus cuentas (Twitter, LinkedIN, etc.) de manera que el visitante acceda solo con un click a los contenidos e informaciones allí publicados. </h2>\n\n<div class=\"mbr-figure\" mbr-style=\"{'width': mediaSize + '%'}\">\n                     <img src=\"@PROJECT_PATH@/assets/images/media-998990-640.jpg-640x464.png\" alt=\"Demo WEB  image_pixabay\" title=\"Demo WEB  image_pixabay\">  \n                    </div>",
          "alias": "witsec-modal-window",
          "_tags": [
            "Extension"
          ],
          "_name": "witsec-modal-window-block",
          "_anchor": "witsec-modal-window-block-t",
          "modalWindow": "<div class=\"modal fade\" id=\"Redes-Sociales\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"Redes-SocialesLabel\" aria-hidden=\"true\">  <div class=\"modal-dialog  modal-dialog-centered\" style=\"height:auto\" role=\"document\">    <div class=\"modal-content\"><div class=\"modal-header\">  <h5 class=\"no-anim modal-title\" id=\"Redes-SocialesLabel\">Redes Sociales</h5>  <a href=\"#\" class=\"no-anim close\" data-dismiss=\"modal\" aria-label=\"Close\"><span aria-hidden=\"true\">&times;</span></a></div><div class=\"modal-body\" id=\"Redes-Sociales_body\"><h2 class=\"mbr-section-subtitle align-center mbr-light pb-3 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showSubTitle\"> \nEl sitio web posee enlaces con los perfiles de sus cuentas (Twitter, LinkedIN, etc.) de manera que el visitante acceda solo con un click a los contenidos e informaciones allí publicados. </h2>\n\n<div class=\"mbr-figure\" mbr-style=\"{'width': mediaSize + '%'}\">\n                     <img src=\"@PROJECT_PATH@/assets/images/media-998990-640.jpg-640x464.png\" alt=\"Demo WEB  image_pixabay\" title=\"Demo WEB  image_pixabay\">  \n                    </div></div><div class=\"modal-footer\"><div class=\"mbr-section-btn\"><a href=\"#\" class=\"no-anim btn btn-secondary display-4\" data-dismiss=\"modal\">Cerrar</a></div></div>    </div>  </div></div><script>document.addEventListener(\"DOMContentLoaded\", function() {  $(\"#Redes-Sociales\").on(\"hidden.bs.modal\", function () {    var html = $( \"#Redes-Sociales_body\" ).html();    $( \"#Redes-Sociales_body\" ).empty();    $( \"#Redes-Sociales_body\" ).append(html);  })});</script>"
        },
        {
          "_name": "preloader1",
          "_styles": {
            "#loading-center": {
              "width": "100%",
              "height": "100vh",
              "position": "relative",
              "background-color": "@preBgcolor"
            },
            "#loading-center-absolute": {
              "position": "absolute",
              "left": "50%",
              "top": "50%",
              "height": "50px",
              "width": "50px",
              "margin-top": "-25px",
              "margin-left": "-25px",
              "-ms-transform": "rotate(45deg)",
              "-webkit-transform": "rotate(45deg)",
              "transform": "rotate(45deg)",
              "-webkit-animation": "loading-center-absolute 1.5s infinite",
              "animation": "loading-center-absolute 1.5s infinite"
            },
            ".object": {
              "width": "25px",
              "height": "25px",
              "background-color": "@preLoadcolor",
              "float": "left"
            },
            "#object_one": {
              "-webkit-animation": "object_one 1.5s infinite",
              "animation": "object_one 1.5s infinite"
            },
            "#object_two": {
              "-webkit-animation": "object_two 1.5s infinite",
              "animation": "object_two 1.5s infinite"
            },
            "#object_three": {
              "-webkit-animation": "object_three 1.5s infinite",
              "animation": "object_three 1.5s infinite"
            },
            "#object_four": {
              "-webkit-animation": "object_four 1.5s infinite",
              "animation": "object_four 1.5s infinite"
            },
            "@-webkit-keyframes loading-center-absolute": {
              "100%": {
                "-webkit-transform": "rotate(-45deg)"
              }
            },
            "@keyframes loading-center-absolute": {
              "100%": {
                "transform": "rotate(-45deg)",
                "-webkit-transform": "rotate(-45deg)"
              }
            },
            "@-webkit-keyframes object_one": {
              "25%": {
                "-webkit-transform": "translate(0, -50px) rotate(-180deg)"
              },
              "100%": {
                "-webkit-transform": "translate(0, 0) rotate(-180deg)"
              }
            },
            "@keyframes object_one": {
              "25%": {
                "transform": "translate(0, -50px) rotate(-180deg)",
                "-webkit-transform": "translate(0, -50px) rotate(-180deg)"
              },
              "100%": {
                "transform": "translate(0, 0) rotate(-180deg)",
                "-webkit-transform": "translate(0, 0) rotate(-180deg)"
              }
            },
            "@-webkit-keyframes object_two": {
              "25%": {
                "-webkit-transform": "translate(50px, 0) rotate(-180deg)"
              },
              "100%": {
                "-webkit-transform": "translate(0, 0) rotate(-180deg)"
              }
            },
            "@keyframes object_two": {
              "25%": {
                "transform": "translate(50px, 0) rotate(-180deg)",
                "-webkit-transform": "translate(50px, 0) rotate(-180deg)"
              },
              "100%": {
                "transform": "translate(0, 0) rotate(-180deg)",
                "-webkit-transform": "translate(0, 0) rotate(-180deg)"
              }
            },
            "@-webkit-keyframes object_three": {
              "25%": {
                "-webkit-transform": "translate(-50px, 0) rotate(-180deg)"
              },
              "100%": {
                "-webkit-transform": "translate(0, 0) rotate(-180deg)"
              }
            },
            "@keyframes object_three": {
              "25%": {
                "transform": "translate(-50px, 0) rotate(-180deg)",
                "-webkit-transform": "translate(-50px, 0) rotate(-180deg)"
              },
              "100%": {
                "transform": "translate(0, 0) rotate(-180deg)",
                "-webkit-transform": "rtranslate(0, 0) rotate(-180deg)"
              }
            },
            "@-webkit-keyframes object_four": {
              "25%": {
                "-webkit-transform": "translate(0, 50px) rotate(-180deg)"
              },
              "100%": {
                "-webkit-transform": "translate(0, 0) rotate(-180deg)"
              }
            },
            "@keyframes object_four": {
              "25%": {
                "transform": "translate(0, 50px) rotate(-180deg)",
                "-webkit-transform": "translate(0, 50px) rotate(-180deg)"
              },
              "100%": {
                "transform": "translate(0, 0) rotate(-180deg)",
                "-webkit-transform": "translate(0, 0) rotate(-180deg)"
              }
            }
          },
          "_customHTML": "<section class=\"mbr-section\" group=\"Dentaura Preloader\" plugins=\"Dentaurapreloader\" once=\"Dentaura Preloader\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"color\" title=\"Background Color\" name=\"preBgcolor\" value=\"#ffffff\">\n        <input type=\"color\" title=\"Preloader Color\" name=\"preLoadcolor\" value=\"#735d78\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n    <!-- Dentaura Preloader --><div id=\"loading-preloader\">\n            <div id=\"loading-center\">\n                <div id=\"loading-center-absolute\">\n                    <div class=\"object\" id=\"object_one\"></div>\n                    <div class=\"object\" id=\"object_two\"></div>\n                    <div class=\"object\" id=\"object_three\"></div>\n                    <div class=\"object\" id=\"object_four\"></div>\n                </div>\n            </div>\n        </div><!--End of Dentaura Preloader -->\n    \n</section>",
